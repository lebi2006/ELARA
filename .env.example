echo DATABASE_URL=postgresql://user:password@localhost:5432/elara_db > .env.example
echo SECRET_KEY=your_secret_key_here >> .env.example
echo ALGORITHM=HS256 >> .env.example
echo ACCESS_TOKEN_EXPIRE_MINUTES=30 >> .env.example
echo MISSION_DURATION_DAYS=180 >> .env.example
echo CREW_SIZE=3 >> .env.example